{
  "name": "backend",
  "private": true,
  "version": "0.1.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "seed": "tsx src/database/seed.ts",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/prisma/schema.prisma"
  },
  "prisma": {
    "seed": "tsx src/database/seed.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "@prisma/client": "^5.20.0",
    "prisma": "^5.20.0",
    "typescript": "^5.6.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "dotenv": "^16.4.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "nodemailer": "^6.9.15",
    "socket.io": "^4.8.0",
    "ioredis": "^5.4.1",
    "bullmq": "^5.19.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "zod": "^3.23.8",
    "express-rate-limit": "^7.4.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "tsx": "^4.19.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^6.4.16",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/morgan": "^1.9.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}